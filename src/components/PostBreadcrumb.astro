---
interface Props {
	title: string;
	section?: string;
	sectionHref?: string;
}

const { title, section, sectionHref } = Astro.props;
---

<nav class="breadcrumb" aria-label="Breadcrumb">
	<ol>
		<li><a href="/">Home</a></li>
		{
			section && (
				<li>{sectionHref ? <a href={sectionHref}>{section}</a> : section}</li>
			)
		}
		<li aria-current="page">{title}</li>
	</ol>
</nav>
